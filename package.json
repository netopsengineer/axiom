{
  "name": "axiom-marketplace-tooling",
  "version": "0.0.0-managed",
  "private": true,
  "description": "CI/release tooling for the axiom Claude Code plugin marketplace. Not published — shipped plugins live under plugins/*.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "scripts": {
    "docs:badges": "node .github/scripts/sync-readme-badges.mjs",
    "docs:badges:check": "node .github/scripts/sync-readme-badges.mjs --check",
    "docs:evals": "node .github/scripts/sync-readme-evals.mjs",
    "docs:evals:check": "node .github/scripts/sync-readme-evals.mjs --check",
    "docs:plugins": "node .github/scripts/sync-readme-plugins.mjs",
    "docs:plugins:check": "node .github/scripts/sync-readme-plugins.mjs --check",
    "docs:readme": "npm run docs:badges && npm run docs:evals && npm run docs:plugins",
    "docs:readme:check": "npm run docs:badges:check && npm run docs:evals:check && npm run docs:plugins:check",
    "check:branch-name": "node .github/scripts/check-branch-name.mjs",
    "check:plugins:local": "node .github/scripts/validate-local-plugins.mjs",
    "check:repo": "node .github/scripts/check-repo-invariants.mjs",
    "check:precommit:security": "prek run actionlint --all-files && prek run shellcheck --all-files && prek run zizmor --all-files",
    "lint:links": "node .github/scripts/check-markdown-links.mjs",
    "lint:spelling": "cspell --no-progress --show-suggestions --gitignore",
    "lint:yaml": "node .github/scripts/check-yaml.mjs",
    "lint": "biome ci",
    "lint:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@j178/prek": "^0.4.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.1",
    "markdown-link-check": "^3.14.2",
    "semantic-release": "^25.0.5",
    "semantic-release-monorepo": "8.0.2",
    "yaml": "^2.9.0"
  }
}
